rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    // ── User profiles ─────────────────────────────────────────────────────────
    match /users/{uid} {
      allow get:  if isOwner(uid);
      allow list: if false;

      // CREATE — new registration or first Google/phone sign-in
      allow create: if isOwner(uid)
        && request.resource.data.uid == uid
        && (request.resource.data.fullName == null
            || (request.resource.data.fullName is string
                && request.resource.data.fullName.size() <= 120))
        && (request.resource.data.email == null
            || (request.resource.data.email is string
                && request.resource.data.email.size() <= 254))
        && (request.resource.data.role == null
            || request.resource.data.role in ['analyst', 'investigator', 'admin']);

      // UPDATE — login refresh or profile edit.
      // Only blocks changing the uid field (immutable identity).
      // Does NOT block other fields — allows merging lastLogin etc.
      allow update: if isOwner(uid)
        && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['uid'])
          || request.resource.data.uid == resource.data.uid
        );

      allow delete: if false;

      // ── Investigations sub-collection ──────────────────────────────────────
      match /investigations/{investigationId} {
        allow get, list: if isOwner(uid);

        allow create: if isOwner(uid)
          && request.resource.data.ownerId == uid
          && request.resource.data.caseId is string
          && request.resource.data.caseId.size() > 0
          && request.resource.data.caseId.size() <= 40
          && request.resource.data.target is string
          && request.resource.data.target.size() > 0
          && request.resource.data.target.size() <= 2048
          && request.resource.data.type is string
          && request.resource.data.type.size() > 0
          && request.resource.data.type.size() <= 40
          && request.resource.data.typeLabel is string
          && request.resource.data.typeLabel.size() <= 80
          && request.resource.data.status in ['Collection', 'Analysis', 'Active', 'Completed']
          && request.resource.data.risk in ['low', 'medium', 'high', 'critical']
          && request.resource.data.platforms is list
          && request.resource.data.summary is string
          && request.resource.data.summary.size() <= 20000
          && request.resource.data.sourceCounts is map
          && request.resource.data.data is map;

        // Allow overwriting/updating own investigations.
        // ownerId is checked against the incoming payload (not the existing doc)
        // so this also works correctly when setDoc merge:true writes to a new path
        // that was never committed (resource.data may not exist on first-time writes
        // that race — the create rule above covers that case instead).
        allow update: if isOwner(uid)
          && request.resource.data.ownerId == uid;

        allow delete: if false;
      }
    }

    // Catch-all deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
