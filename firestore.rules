rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function requiredUserCreateKeys() {
      return [
        'uid',
        'fullName',
        'email',
        'phone',
        'badgeID',
        'designation',
        'department',
        'role',
        'status',
        'verified',
        'authProvider',
        'createdAt',
        'updatedAt',
        'lastLogin'
      ];
    }

    function allowedUserKeys() {
      return [
        'uid',
        'fullName',
        'email',
        'phone',
        'badgeID',
        'designation',
        'department',
        'role',
        'status',
        'verified',
        'authProvider',
        'createdAt',
        'updatedAt',
        'lastLogin',
        'photoURL',
        'displayName'
      ];
    }

    function validNullableString(value, maxLength) {
      return value == null || (value is string && value.size() <= maxLength);
    }

    function validUserDocument(uid) {
      return request.resource.data.keys().hasOnly(allowedUserKeys())
        && request.resource.data.keys().hasAll(requiredUserCreateKeys())
        && request.resource.data.uid == uid
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.fullName is string
        && request.resource.data.fullName.size() > 0
        && request.resource.data.fullName.size() <= 120
        && validNullableString(request.resource.data.email, 254)
        && validNullableString(request.resource.data.phone, 32)
        && validNullableString(request.resource.data.badgeID, 64)
        && validNullableString(request.resource.data.designation, 80)
        && validNullableString(request.resource.data.department, 120)
        && request.resource.data.role in ['analyst', 'investigator', 'admin']
        && request.resource.data.status == 'active'
        && request.resource.data.verified == false
        && request.resource.data.authProvider in ['email', 'google', 'phone']
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time
        && request.resource.data.lastLogin == request.time;
    }

    function userMutableKeys() {
      return [
        'fullName',
        'email',
        'phone',
        'badgeID',
        'designation',
        'department',
        'authProvider',
        'photoURL',
        'displayName',
        'lastLogin',
        'updatedAt'
      ];
    }

    function validUserUpdate(uid) {
      return request.resource.data.uid == resource.data.uid
        && resource.data.uid == uid
        && request.resource.data.role == resource.data.role
        && request.resource.data.status == resource.data.status
        && request.resource.data.verified == resource.data.verified
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(userMutableKeys())
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['fullName'])
          || (request.resource.data.fullName is string
            && request.resource.data.fullName.size() > 0
            && request.resource.data.fullName.size() <= 120))
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['email'])
          || validNullableString(request.resource.data.email, 254))
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['phone'])
          || validNullableString(request.resource.data.phone, 32))
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['badgeID'])
          || validNullableString(request.resource.data.badgeID, 64))
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['designation'])
          || validNullableString(request.resource.data.designation, 80))
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['department'])
          || validNullableString(request.resource.data.department, 120))
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['authProvider'])
          || request.resource.data.authProvider in ['email', 'google', 'phone'])
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['photoURL'])
          || validNullableString(request.resource.data.photoURL, 2048))
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['displayName'])
          || validNullableString(request.resource.data.displayName, 120))
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['lastLogin'])
          || request.resource.data.lastLogin == request.time)
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['updatedAt'])
          || request.resource.data.updatedAt == request.time);
    }



    function allowedInvestigationKeys() {
      return [
        'ownerId',
        'caseId',
        'target',
        'type',
        'typeLabel',
        'status',
        'risk',
        'platforms',
        'startedAt',
        'summary',
        'sourceCounts',
        'data',
        'createdAt',
        'updatedAt'
      ];
    }

    function validInvestigationDocument(uid) {
      return request.resource.data.keys().hasOnly(allowedInvestigationKeys())
        && request.resource.data.ownerId == uid
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.caseId is string
        && request.resource.data.caseId.size() > 0
        && request.resource.data.caseId.size() <= 40
        && request.resource.data.target is string
        && request.resource.data.target.size() > 0
        && request.resource.data.target.size() <= 2048
        && request.resource.data.type is string
        && request.resource.data.type.size() > 0
        && request.resource.data.type.size() <= 40
        && request.resource.data.typeLabel is string
        && request.resource.data.typeLabel.size() > 0
        && request.resource.data.typeLabel.size() <= 80
        && request.resource.data.status in ['Collection', 'Analysis', 'Active', 'Completed']
        && request.resource.data.risk in ['low', 'medium', 'high', 'critical']
        && request.resource.data.platforms is list
        && request.resource.data.platforms.size() <= 12
        && request.resource.data.startedAt is string
        && request.resource.data.summary is string
        && request.resource.data.summary.size() <= 20000
        && request.resource.data.sourceCounts is map
        && request.resource.data.data is map
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;
    }

    match /users/{uid} {
      allow get: if isOwner(uid);
      allow list: if false;
      allow create: if isOwner(uid) && validUserDocument(uid);
      allow update: if isOwner(uid) && validUserUpdate(uid);
      allow delete: if false;
    }

    match /users/{uid}/investigations/{investigationId} {
      allow get, list: if isOwner(uid);
      allow create, update: if isOwner(uid) && validInvestigationDocument(uid);
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
